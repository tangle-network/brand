{
  "name": "@tangle-network/design-system-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Tangle design-system foundation — brand tokens + generic UI components.",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/tangle-network/brand" },
  "type": "module",
  "scripts": {
    "build": "pnpm -r run --if-present build",
    "dev": "pnpm -r --parallel run --if-present dev",
    "test": "echo \"no tests yet (lands in Phase B)\" && exit 0",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@10.33.3",
  "engines": { "node": ">=22" }
}
