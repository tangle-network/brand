{
  "name": "@tangle-network/ui",
  "version": "2.1.0",
  "description": "Generic React UI components for Tangle products — primitives, chat, run, files, editor, markdown.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tangle-network/brand",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/tangle-network/brand/issues"
  },
  "homepage": "https://github.com/tangle-network/brand",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "import": "./dist/primitives.js",
      "default": "./dist/primitives.js"
    },
    "./chat": {
      "types": "./dist/chat.d.ts",
      "import": "./dist/chat.js",
      "default": "./dist/chat.js"
    },
    "./run": {
      "types": "./dist/run.d.ts",
      "import": "./dist/run.js",
      "default": "./dist/run.js"
    },
    "./openui": {
      "types": "./dist/openui.d.ts",
      "import": "./dist/openui.js",
      "default": "./dist/openui.js"
    },
    "./files": {
      "types": "./dist/files.d.ts",
      "import": "./dist/files.js",
      "default": "./dist/files.js"
    },
    "./editor": {
      "types": "./dist/editor.d.ts",
      "import": "./dist/editor.js",
      "default": "./dist/editor.js"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js",
      "default": "./dist/markdown.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "default": "./dist/auth.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js",
      "default": "./dist/hooks.js"
    },
    "./sdk-hooks": {
      "types": "./dist/sdk-hooks.d.ts",
      "import": "./dist/sdk-hooks.js",
      "default": "./dist/sdk-hooks.js"
    },
    "./stores": {
      "types": "./dist/stores.d.ts",
      "import": "./dist/stores.js",
      "default": "./dist/stores.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "default": "./dist/utils.js"
    },
    "./tool-previews": {
      "types": "./dist/tool-previews.d.ts",
      "import": "./dist/tool-previews.js",
      "default": "./dist/tool-previews.js"
    },
    "./nav": {
      "types": "./dist/nav.d.ts",
      "import": "./dist/nav.js",
      "default": "./dist/nav.js"
    }
  },
  "scripts": {
    "build": "tsup && node ../../scripts/validate-dist.mjs",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@pierre/trees": "1.0.0-beta.3",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "marked": "^17.0.5",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.2.1",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.0.2",
    "turndown": "^7.2.2"
  },
  "peerDependencies": {
    "@tangle-network/brand": "workspace:^",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "react-router": "^7"
  },
  "peerDependenciesMeta": {
    "@nanostores/react": {
      "optional": true
    },
    "nanostores": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "@hocuspocus/provider": {
      "optional": true
    },
    "@tiptap/core": {
      "optional": true
    },
    "@tiptap/react": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    },
    "@tiptap/extension-collaboration": {
      "optional": true
    },
    "@tiptap/extension-collaboration-caret": {
      "optional": true
    },
    "yjs": {
      "optional": true
    },
    "react-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hocuspocus/provider": "^2.15.0",
    "@nanostores/react": "^0.8.4",
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-collaboration": "^3.20.4",
    "@tiptap/extension-collaboration-caret": "^3.7.0",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@types/react": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/turndown": "^5.0.5",
    "nanostores": "^0.11.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@storybook/react": "^8.6.18",
    "tsup": "^8.3.5",
    "typescript": "^5.6.0",
    "yjs": "^13.6.0",
    "react-router": "^7"
  },
  "keywords": [
    "tangle",
    "ui",
    "react",
    "components",
    "design-system"
  ]
}
